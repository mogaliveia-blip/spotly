rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (isSignedIn() && exists(userDocPath)) {
        return get(userDocPath).data.role;
      }
      return null;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isEditorOrAdmin() {
      return getUserRole() in ['editor', 'admin'];
    }

    match /poi-images/{poiId}/{allPaths=**} {
      allow read: if true;

      allow write: if isEditorOrAdmin()
        && (
          request.method == 'delete' ||
          (
            request.resource.size < 5 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    match /marketing/{allPaths=**} {
      allow read: if true;

      allow write: if isAdmin()
        && (
          request.method == 'delete' ||
          (
            request.resource.size < 2 * 1024 * 1024
            && request.resource.contentType.matches('image/(jpeg|png|webp)')
          )
        );
    }
  }
}
