rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Note: La vérification de rôle a été temporairement enlevée pour débugger
    // les problèmes de permission. La règle se base uniquement sur l'authentification.
    function isAllowedToWrite() {
      return isSignedIn();
    }

    match /poi-images/{poiId}/{allPaths=**} {

      allow read: if true;

      // Simplification : Tout utilisateur connecté peut écrire (upload/delete)
      // des images de moins de 5MB.
      allow write: if isAllowedToWrite()
        && (
          request.method == 'delete' ||
          (
            request.resource.size < 5 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }
  }
}
