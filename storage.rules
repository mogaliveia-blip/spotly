rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      // Note: Changed to getUserRole in the recommended version, 
      // but keeping it simple to align with existing functions.
      // The logic remains the same.
      return get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isEditorOrAdmin() {
      return isSignedIn() && getUserData().role in ['editor', 'admin'];
    }

    // All POI images (header + gallery)
    match /poi-images/{poiId}/{allPaths=**} {
      allow read: if true;

      // Separate create/update from delete for robustness
      allow write: if isEditorOrAdmin() && (
        // Allow deletion by authorized users without checking resource
        request.method == 'delete' ||
        // For uploads (create/update), validate size and content type
        (
          request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        )
      );
    }
  }
}
