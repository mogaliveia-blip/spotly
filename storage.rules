rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() &&
        firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.role == 'owner';
    }

    function isEventPublished(eventId) {
      return firestore.exists(
        /databases/(default)/documents/events/$(eventId)
      ) &&
        firestore.get(
          /databases/(default)/documents/events/$(eventId)
        ).data.status == 'published';
    }

    function getEventRole(eventId) {
      let memberPath =
        /databases/(default)/documents/events/$(eventId)/members/$(request.auth.uid);

      return firestore.exists(memberPath)
        ? firestore.get(memberPath).data.role
        : 'none';
    }

    function isEventAdmin(eventId) {
      return isSignedIn() &&
        (
          firestore.get(
            /databases/(default)/documents/events/$(eventId)
          ).data.adminId == request.auth.uid ||
          getEventRole(eventId) == 'admin' ||
          isOwner()
        );
    }

    function isAdminOrEditor(eventId) {
      let role = getEventRole(eventId);

      return role == 'admin' ||
             role == 'editor' ||
             isEventAdmin(eventId);
    }

    match /events/{eventId}/poi-images/{allPaths=**} {
      allow read: if isEventPublished(eventId) || isAdminOrEditor(eventId);
      allow write: if isAdminOrEditor(eventId);
    }

    match /events/{eventId}/marketing/{allPaths=**} {
      allow read: if true;
      allow write: if isEventAdmin(eventId);
    }
  }
}
