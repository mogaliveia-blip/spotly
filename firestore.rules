rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       UTILITAIRES GLOBAUX
    ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isGlobalAdmin() {
      return isSignedIn() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /* =========================
       UTILITAIRES ÉVÉNEMENTS
    ========================= */

    function getEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }

    function isEventOwner(eventId) {
      return isSignedIn() && getEvent(eventId).ownerId == request.auth.uid;
    }

    function getMemberRole(eventId) {
      let path = /databases/$(database)/documents/events/$(eventId)/members/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'none';
    }

    function hasEventRole(eventId, roles) {
      return isSignedIn() && (getMemberRole(eventId) in roles || isEventOwner(eventId) || isGlobalAdmin());
    }

    function isEventAdmin(eventId) {
      return hasEventRole(eventId, ['admin']);
    }

    function isEventEditor(eventId) {
      return hasEventRole(eventId, ['admin', 'editor']);
    }

    function isEventPublic(eventId) {
      return getEvent(eventId).status == 'published';
    }

    /* =========================
       RACINE : EVENTS
    ========================= */

    match /events/{eventId} {
      // Lecture publique si publié, sinon restreinte aux membres
      allow read: if isEventPublic(eventId) || hasEventRole(eventId, ['admin', 'editor', 'viewer']);
      
      // Création : n'importe quel utilisateur connecté peut créer un event (il en devient owner)
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Update/Delete : owner ou global admin uniquement
      allow update, delete: if isEventOwner(eventId) || isGlobalAdmin();

      /* ---- MEMBRES DE L'EVENT ---- */
      match /members/{userId} {
        allow read: if hasEventRole(eventId, ['admin', 'editor', 'viewer']);
        allow write: if isEventAdmin(eventId);
      }

      /* ---- CONFIG DE L'EVENT ---- */
      match /config/{configId} {
        allow read: if isEventPublic(eventId) || hasEventRole(eventId, ['admin', 'editor', 'viewer']);
        allow write: if isEventAdmin(eventId);
      }

      /* ---- POIS DE L'EVENT ---- */
      match /pois/{poiId} {
        allow read: if isEventPublic(eventId) || hasEventRole(eventId, ['admin', 'editor', 'viewer']);
        allow write: if isEventEditor(eventId);

        /* ---- REVIEWS DES POIS ---- */
        match /reviews/{reviewId} {
          allow read: if isEventPublic(eventId) || hasEventRole(eventId, ['admin', 'editor', 'viewer']);
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isEventAdmin(eventId));
        }
      }

      /* ---- PROJECTION LITE DE L'EVENT ---- */
      match /pois_public/{poiId} {
        allow read: if true;
        allow write: if isEventEditor(eventId);
      }
    }

    /* ============================================================
       COMPATIBILITÉ : ANCIEN SCHÉMA GLOBAL (À SUPPRIMER APRÈS MIGRATION)
    ============================================================ */

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isGlobalAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId && !('role' in request.resource.data)) || isGlobalAdmin();
      allow delete: if isGlobalAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    match /pois/{poiId} {
      allow read: if true;
      allow create, update, delete: if isGlobalAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isGlobalAdmin());
      }
    }

    match /pois_public/{poiId} {
      allow read: if true;
      allow write: if isGlobalAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);
    }
  }
}