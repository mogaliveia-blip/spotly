rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       Fonctions utilitaires
       ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isRole(role) {
        return isSignedIn() && getUserData(request.auth.uid).role == role;
    }
    
    function isOneOfRoles(roles) {
        return isSignedIn() && getUserData(request.auth.uid).role in roles;
    }

    function isAdmin() {
      return isOneOfRoles(['admin']);
    }

    function isEditorOrAdmin() {
      return isOneOfRoles(['editor', 'admin']);
    }

    /* =========================
       USERS
       ========================= */
    match /users/{userId} {

      // Lecture : soi-même ou admin
      allow read: if isOwner(userId) || isAdmin();

      // Création : uniquement son propre document
      allow create: if isSignedIn()
        && request.auth.uid == userId;

      // Mise à jour du profil (sans rôle)
      allow update: if isOwner(userId)
        && !('role' in request.resource.data);

      // Modification du rôle : admin uniquement
      allow update: if isAdmin()
        && ('role' in request.resource.data);

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }

    /* =========================
       POIS
       ========================= */
    match /pois/{poiId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isEditorOrAdmin();

      /* =========================
         REVIEWS (sous-collection)
         ========================= */
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
