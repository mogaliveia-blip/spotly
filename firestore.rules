rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       Fonctions utilitaires
       ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isOneOfRoles(roles) {
      return isSignedIn()
        && getUserData(request.auth.uid).role in roles;
    }

    function isAdmin() {
      return isOneOfRoles(['admin']);
    }

    function isEditorOrAdmin() {
      return isOneOfRoles(['editor', 'admin']);
    }

    /* =========================
       Listes de valeurs autorisées
       ========================= */
    function mainCategories() {
      return [
        'programmation', 'nourriture_boissons', 'services_essentiels',
        'logistique_mobilite', 'merchandising_partenaires', 'espaces_specifiques'
      ];
    }

    function subCategories() {
      return [
        'concert_headliner', 'concert_scene_secondaire', 'spectacle_rue', 'dj_set',
        'food_truck', 'restaurant', 'bar', 'buvette',
        'toilettes', 'poste_secours', 'securite', 'point_eau',
        'entree_principale', 'parking', 'navette', 'info_point', 'acces_pmr',
        'boutique_officielle', 'stand_partenaire', 'sponsor',
        'espace_vip', 'espace_enfant', 'zone_detente', 'backstage'
      ];
    }
    
    function isValidCategoryPair(mainCat, subCat) {
      return (mainCat == 'programmation' && subCat in ['concert_headliner', 'concert_scene_secondaire', 'spectacle_rue', 'dj_set'])
        || (mainCat == 'nourriture_boissons' && subCat in ['food_truck', 'restaurant', 'bar', 'buvette'])
        || (mainCat == 'services_essentiels' && subCat in ['toilettes', 'poste_secours', 'securite', 'point_eau'])
        || (mainCat == 'logistique_mobilite' && subCat in ['entree_principale', 'parking', 'navette', 'info_point', 'acces_pmr'])
        || (mainCat == 'merchandising_partenaires' && subCat in ['boutique_officielle', 'stand_partenaire', 'sponsor'])
        || (mainCat == 'espaces_specifiques' && subCat in ['espace_vip', 'espace_enfant', 'zone_detente', 'backstage']);
    }

    /* =========================
       USERS
       ========================= */
    match /users/{userId} {

      // Lecture : soi-même OU admin
      allow read: if isOwner(userId) || isAdmin();

      // Création : uniquement son propre document (signup)
      // Le rôle par défaut DOIT être "user"
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'user';

      // Mise à jour du profil personnel (sans le rôle)
      allow update: if isOwner(userId)
        && !('role' in request.resource.data);

      // Modification du rôle : admin uniquement
      allow update: if isAdmin()
        && ('role' in request.resource.data);

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }
    
    /* =========================
       CONFIG
       ========================= */
    match /config/main {
      // Lecture publique pour que le client connaisse l'état de la landing page
      allow read: if true;
      // Écriture : admin uniquement
      allow write: if isAdmin();
    }


    /* =========================
       POIS
       ========================= */
    match /pois/{poiId} {

      // Lecture publique
      allow read: if true;

      // Création / modification :
      // uniquement editor ou admin, avec validation des catégories
      allow create, update: if isEditorOrAdmin()
        && request.resource.data.mainCategory is string
        && request.resource.data.mainCategory in mainCategories()
        && request.resource.data.subCategory is string
        && request.resource.data.subCategory in subCategories()
        && isValidCategoryPair(request.resource.data.mainCategory, request.resource.data.subCategory);
      
      // Suppression : editor ou admin
      allow delete: if isEditorOrAdmin();

      /* =========================
         REVIEWS (sous-collection)
         ========================= */
      match /reviews/{reviewId} {

        // Lecture publique
        allow read: if true;

        // Création : utilisateur connecté, auteur obligatoire
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;

        // Modification / suppression : auteur uniquement
        allow update, delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
