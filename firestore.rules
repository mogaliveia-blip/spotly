rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    function getEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isEventPublished(eventId) {
      return getEvent(eventId).data.status == "published";
    }

    function getMember(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/members/$(getUserId()));
    }

    function isEventMember(eventId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/events/$(eventId)/members/$(getUserId()));
    }

    function getRole(eventId) {
      return isEventMember(eventId)
        ? getMember(eventId).data.role
        : null;
    }

    function isOwner(eventId) {
      return isAuthenticated() && getEvent(eventId).data.ownerId == getUserId();
    }

    function isAdmin(eventId) {
      return isEventMember(eventId) && getRole(eventId) == "admin";
    }

    function isEditor(eventId) {
      return isEventMember(eventId) && getRole(eventId) == "editor";
    }

    function isAdminOrEditor(eventId) {
      return isOwner(eventId) || isAdmin(eventId) || isEditor(eventId);
    }

    function isAdminOnly(eventId) {
      return isOwner(eventId) || isAdmin(eventId);
    }

    /* =========================
       EVENTS ROOT
    ========================= */

    match /events/{eventId} {
      // lecture publique si publié
      allow read: if isEventPublished(eventId) || isEventMember(eventId);

      // création d’un event
      allow create: if isAuthenticated();

      // modification
      allow update, delete: if isOwner(eventId);
    }

    /* =========================
       MEMBERS
    ========================= */

    match /events/{eventId}/members/{userId} {
      allow read: if isEventMember(eventId);

      allow create: if isOwner(eventId);

      allow update, delete: if isAdminOnly(eventId);
    }

    /* =========================
       CONFIG
    ========================= */

    match /events/{eventId}/config/{docId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);

      allow write: if isAdminOnly(eventId);
    }

    /* =========================
       POIS FULL
    ========================= */

    match /events/{eventId}/pois/{poiId} {
      allow read: if isEventMember(eventId);

      allow create, update, delete: if isAdminOrEditor(eventId);
    }

    /* =========================
       POIS LITE (CARTE)
    ========================= */

    match /events/{eventId}/pois_public/{poiId} {
      // 👇 CRUCIAL : lecture publique
      allow read: if isEventPublished(eventId) || isEventMember(eventId);

      allow write: if isAdminOrEditor(eventId);
    }

    /* =========================
       REVIEWS
    ========================= */

    match /events/{eventId}/pois/{poiId}/reviews/{reviewId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);

      allow create: if isAuthenticated();

      allow update, delete: if isAdminOrEditor(eventId)
        || request.auth.uid == resource.data.userId;
    }

    /* =========================
       LEGACY MODE (TEMPORAIRE)
    ========================= */

    match /pois/{poiId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /pois_public/{poiId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}