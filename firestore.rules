rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data;
    }

    // Vérifie si l'utilisateur est approuvé par l'admin global
    function isApproved() {
      return isAuthenticated() && getUserData().isApproved == true;
    }

    // Vérifie si l'utilisateur est le Propriétaire Global (Owner)
    // Seul le rôle 'owner' a désormais des privilèges sur toute la plateforme
    function isGlobalAdmin() {
      let role = getUserData().role;
      return isAuthenticated() && role == "owner";
    }

    function getEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isEventPublished(eventId) {
      let eventPath = /databases/$(database)/documents/events/$(eventId);
      return exists(eventPath) && get(eventPath).data.status == "published";
    }

    function isEventMember(eventId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/events/$(eventId)/members/$(getUserId())) ||
        isGlobalAdmin()
      );
    }

    function getRole(eventId) {
      return isEventMember(eventId)
        ? (
            isGlobalAdmin()
              ? "admin"
              : get(
                  /databases/$(database)/documents/events/$(eventId)/members/$(getUserId())
                ).data.role
          )
        : null;
    }

    function isEventAdmin(eventId) {
      return isAuthenticated() &&
        (
          getEvent(eventId).data.adminId == getUserId() ||
          isGlobalAdmin()
        );
    }

    function isAdminOnly(eventId) {
      let role = getRole(eventId);
      return role == "admin" || isEventAdmin(eventId);
    }

    function isAdminOrEditor(eventId) {
      let role = getRole(eventId);
      return role == "admin" || role == "editor" || isEventAdmin(eventId);
    }

    /* =========================
       EVENTS ROOT
    ========================= */

    match /events/{eventId} {
      // Lecture publique pour résolution slug -> eventId
      allow read: if true;

      // Création : utilisateurs approuvés
      allow create: if isApproved();

      // Gestion : admin événement ou admin global
      allow update, delete: if isEventAdmin(eventId);
    }

    /* =========================
       MEMBERS
    ========================= */

    match /events/{eventId}/members/{userId} {
      allow read: if isAuthenticated();

      // Ajout de membres
      allow create: if isApproved() &&
        (
          request.auth.uid == userId ||
          isEventAdmin(eventId)
        );

      // Gestion membres
      allow update, delete: if isAdminOnly(eventId);
    }

    // Lecture générique de members
    match /{path=**}/members/{userId} {
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isGlobalAdmin()
        );
    }

    /* =========================
       POIS PUBLIC
    ========================= */

    match /events/{eventId}/pois_public/{poiId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);
      allow write: if isAdminOrEditor(eventId);
    }

    /* =========================
       POIS PRIVÉS + REVIEWS
    ========================= */

    match /events/{eventId}/pois/{poiId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);
      allow create, update, delete: if isAdminOrEditor(eventId);

      match /reviews/{reviewId} {
        allow read: if isEventPublished(eventId) || isEventMember(eventId);

        // Création d’avis
        allow create: if isApproved();

        // Modification/suppression
        allow update, delete: if
          isAdminOrEditor(eventId) ||
          request.auth.uid == resource.data.userId;
      }
    }

    /* =========================
       CONFIG EVENT
    ========================= */

    match /events/{eventId}/config/{docId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);
      allow write: if isAdminOnly(eventId);
    }

    /* =========================
       CONFIG GLOBALE (PORTAL)
    ========================= */

    match /config/{docId} {
      // Lecture publique pour la page racine "/"
      allow read: if true;

      // Modification réservée au propriétaire global
      allow write: if isGlobalAdmin();
    }

    /* =========================
       USERS GLOBAL
    ========================= */

    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isGlobalAdmin()
        );

      allow create: if isAuthenticated() &&
        request.auth.uid == userId;

      allow update: if
        isGlobalAdmin() ||
        (
          request.auth.uid == userId &&
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny(['isApproved', 'role'])
        );
    }

    /* =========================
       LEGACY ROOT POIS
    ========================= */

    match /pois/{poiId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    match /pois_public/{poiId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }
  }
}