rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       Fonctions utilitaires
       ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isOneOfRoles(roles) {
      return isSignedIn()
        && getUserData(request.auth.uid).role in roles;
    }

    function isAdmin() {
      return isOneOfRoles(['admin']);
    }

    function isEditorOrAdmin() {
      return isOneOfRoles(['editor', 'admin']);
    }

    /* =========================
       USERS
       ========================= */
    match /users/{userId} {

      // Lecture : soi-même OU admin
      allow read: if isOwner(userId) || isAdmin();

      // Création : uniquement son propre document (signup)
      // Le rôle par défaut DOIT être "user"
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'user';

      // Mise à jour du profil personnel (sans le rôle)
      allow update: if isOwner(userId)
        && !('role' in request.resource.data);

      // Modification du rôle : admin uniquement
      allow update: if isAdmin()
        && ('role' in request.resource.data);

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }
    
    /* =========================
       CONFIG
       ========================= */
    match /config/main {
      // Lecture publique pour que le client connaisse l'état de la landing page
      allow read: if true;
      // Écriture : admin uniquement
      allow write: if isAdmin();
    }


    /* =========================
       POIS
       ========================= */
    match /pois/{poiId} {

      // Lecture publique
      allow read: if true;

      // Création / modification / suppression :
      // uniquement editor ou admin
      allow create, update, delete: if isEditorOrAdmin();

      /* =========================
         REVIEWS (sous-collection)
         ========================= */
      match /reviews/{reviewId} {

        // Lecture publique
        allow read: if true;

        // Création : utilisateur connecté, auteur obligatoire
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;

        // Modification / suppression : auteur uniquement
        allow update, delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
