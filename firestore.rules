rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    // ✅ Nouvel helper : vérifie si l'utilisateur est approuvé par l'admin
    function isApproved() {
      let userPath = /databases/$(database)/documents/users/$(getUserId());
      return isAuthenticated() && exists(userPath) && get(userPath).data.isApproved == true;
    }

    function isGlobalAdmin() {
      let userPath = /databases/$(database)/documents/users/$(getUserId());
      return isAuthenticated() && exists(userPath) && get(userPath).data.role == "admin";
    }

    function getEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isEventPublished(eventId) {
      let eventPath = /databases/$(database)/documents/events/$(eventId);
      return exists(eventPath) && get(eventPath).data.status == "published";
    }

    function getMember(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/members/$(getUserId()));
    }

    function isEventMember(eventId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/events/$(eventId)/members/$(getUserId())) ||
        isGlobalAdmin()
      );
    }

    function getRole(eventId) {
      return isEventMember(eventId)
        ? (isGlobalAdmin() ? "admin" : getMember(eventId).data.role)
        : null;
    }

    function isOwner(eventId) {
      return isAuthenticated() &&
        (getEvent(eventId).data.ownerId == getUserId() || isGlobalAdmin());
    }

    function isAdmin(eventId) {
      return isEventMember(eventId) &&
        (getRole(eventId) == "admin" || isGlobalAdmin());
    }

    function isEditor(eventId) {
      return isEventMember(eventId) &&
        (getRole(eventId) == "editor" || isGlobalAdmin());
    }

    function isAdminOrEditor(eventId) {
      return isOwner(eventId) || isAdmin(eventId) || isEditor(eventId);
    }

    function isAdminOnly(eventId) {
      return isOwner(eventId) || isAdmin(eventId);
    }

    /* =========================
       EVENTS ROOT
    ========================= */

    match /events/{eventId} {
      // Lecture restreinte aux membres OU si publié (mais tjs isApproved pour interagir)
      allow read: if isAuthenticated() && (
        isEventPublished(eventId) || isEventMember(eventId)
      );

      // ✅ Création restreinte aux utilisateurs APPROUVÉS uniquement
      allow create: if isApproved();

      allow update, delete: if isOwner(eventId);
    }

    /* =========================
       MEMBERS
    ========================= */

    match /events/{eventId}/members/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(eventId);
      allow update, delete: if isAdminOnly(eventId);
    }

    // IMPORTANT : nécessaire pour collectionGroup fetchUserEvents
    match /{path=**}/members/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
    }

    /* =========================
       CONFIG
    ========================= */

    match /events/{eventId}/config/{docId} {
      allow read: if isAuthenticated() && (
        isEventPublished(eventId) || isEventMember(eventId)
      );

      allow write: if isAdminOnly(eventId);
    }

    /* =========================
       POIS (FULL)
    ========================= */

    match /events/{eventId}/pois/{poiId} {
      allow read: if isAuthenticated() && (
        isEventPublished(eventId) || isEventMember(eventId)
      );

      allow create, update, delete: if isAdminOrEditor(eventId);
    }

    /* =========================
       POIS LITE (CARTE)
    ========================= */

    match /events/{eventId}/pois_public/{poiId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);
      allow write: if isAdminOrEditor(eventId);
    }

    /* =========================
       REVIEWS
    ========================= */

    match /events/{eventId}/pois/{poiId}/reviews/{reviewId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);
      allow create: if isApproved(); // ✅ Seuls les approuvés peuvent commenter (optionnel, selon besoin)
      allow update, delete: if isAdminOrEditor(eventId) || request.auth.uid == resource.data.userId;
    }

    /* =========================
       USERS GLOBAL
    ========================= */

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isGlobalAdmin());

      // ✅ Sécurisation du champ isApproved et role
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      allow update: if isGlobalAdmin() || (
        request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isApproved', 'role'])
      );
    }

    /* =========================
       LEGACY (BACKWARD COMPATIBILITY)
    ========================= */

    match /pois/{poiId} {
      allow read: if true;
      allow write: if isApproved() && isGlobalAdmin();
    }

    match /pois_public/{poiId} {
      allow read: if true;
      allow write: if isApproved() && isGlobalAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isApproved() && isGlobalAdmin();
    }
  }
}
