rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       Fonctions utilitaires
       ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole(userId) {
      let userDoc = get(
        /databases/$(database)/documents/users/$(userId)
      );
      return userDoc.exists ? userDoc.data.role : 'user';
    }

    function isAdmin() {
      return isSignedIn()
        && getUserRole(request.auth.uid) == 'admin';
    }

    function isEditorOrAdmin() {
      return isSignedIn()
        && getUserRole(request.auth.uid) in ['editor', 'admin'];
    }

    /* =========================
       USERS
       ========================= */
    match /users/{userId} {

      // Lecture : soi-même ou admin
      allow read: if isOwner(userId) || isAdmin();

      // Création : uniquement son propre document
      allow create: if isSignedIn()
        && request.auth.uid == userId;

      // Mise à jour du profil (sans rôle)
      allow update: if isOwner(userId)
        && !('role' in request.resource.data);

      // Modification du rôle : admin uniquement
      allow update: if isAdmin()
        && ('role' in request.resource.data);

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }

    /* =========================
       POIS
       ========================= */
    match /pois/{poiId} {

      // Lecture publique
      allow read: if true;

      // Création / modification / suppression : editor ou admin
      allow create, update, delete: if isEditorOrAdmin();

      /* =========================
         REVIEWS (sous-collection)
         ========================= */
      match /reviews/{reviewId} {

        // Lecture publique
        allow read: if true;

        // Création : utilisateur authentifié, propriétaire de l'avis
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;

        // Modification / suppression : uniquement le propriétaire
        allow update, delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
