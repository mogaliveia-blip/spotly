rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      // Lit le rôle depuis le document de l'utilisateur dans Firestore.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isEditorOrAdmin() {
      if (!isSignedIn()) {
        return false;
      }
      let role = getUserRole();
      return role in ['editor', 'admin'];
    }

    // Les utilisateurs peuvent créer leur propre profil, et ne peuvent que lire/modifier/supprimer le leur.
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      // Un nouvel utilisateur peut créer son profil.
      allow create: if isSignedIn(); 
    }

    // Les POIs sont publics en lecture, mais seuls les éditeurs ou admins peuvent les modifier.
    match /pois/{poiId} {
      allow read: if true;
      allow create, update, delete: if isEditorOrAdmin();
    }
    
    // Les avis sont publics, les utilisateurs peuvent créer les leurs.
    // Un utilisateur peut modifier/supprimer son propre avis.
    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        // Vérifie que l'utilisateur qui modifie est bien le créateur de l'avis.
        allow update, delete: if isOwner(request.resource.data.userId);
    }
  }
}
