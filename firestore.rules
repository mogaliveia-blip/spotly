rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserRole(userId) {
      // Lit le rôle depuis le document de l'utilisateur dans Firestore.
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isAdmin() {
      if (!isSignedIn()) {
        return false;
      }
      return getUserRole(request.auth.uid) == 'admin';
    }

    function isEditorOrAdmin() {
      if (!isSignedIn()) {
        return false;
      }
      let role = getUserRole(request.auth.uid);
      return role in ['editor', 'admin'];
    }

    // Un utilisateur peut créer son propre profil, lire/modifier/supprimer le sien.
    // Un admin peut lire la liste des utilisateurs.
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow list: if isAdmin();
      // Un nouvel utilisateur peut créer son profil.
      allow create: if isSignedIn(); 
    }

    // Les POIs sont publics en lecture, mais seuls les éditeurs ou admins peuvent les modifier.
    match /pois/{poiId} {
      allow read: if true;
      allow create, update, delete: if isEditorOrAdmin();

      // Les avis sont publics, les utilisateurs peuvent créer les leurs.
      // Un utilisateur peut modifier/supprimer son propre avis.
      match /reviews/{reviewId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          // Vérifie que l'utilisateur qui modifie est bien le créateur de l'avis.
          allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }
  }
}
