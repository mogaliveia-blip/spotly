rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data;
    }

    // Utilisateur validé par owner
    function isApproved() {
      return isAuthenticated() &&
        getUserData().isApproved == true;
    }

    // Owner plateforme
    function isOwner() {
      return isAuthenticated() &&
        getUserData().role == "owner";
    }

    function getEvent(eventId) {
      return get(
        /databases/$(database)/documents/events/$(eventId)
      );
    }

    function isEventPublished(eventId) {
      let eventPath =
        /databases/$(database)/documents/events/$(eventId);

      return exists(eventPath) &&
        get(eventPath).data.status == "published";
    }

    function isEventMember(eventId) {
      return isAuthenticated() &&
        (
          exists(
            /databases/$(database)/documents/events/$(eventId)/members/$(getUserId())
          ) ||
          isOwner()
        );
    }

    function getRole(eventId) {
      return isEventMember(eventId)
        ? (
            isOwner()
              ? "admin"
              : get(
                  /databases/$(database)/documents/events/$(eventId)/members/$(getUserId())
                ).data.role
          )
        : null;
    }

    function isEventAdmin(eventId) {
      let role = getRole(eventId);

      return isAuthenticated() &&
        (
          role == "admin" ||
          getEvent(eventId).data.adminId == getUserId() ||
          isOwner()
        );
    }

    function isAdminOrEditor(eventId) {
      let role = getRole(eventId);

      return
        role == "admin" ||
        role == "editor" ||
        isEventAdmin(eventId);
    }

    /* =========================
       EVENTS ROOT
    ========================= */

    match /events/{eventId} {
      allow read: if true;

      allow create: if isApproved();

      allow update, delete: if isEventAdmin(eventId);
    }

    /* =========================
       MEMBERS
    ========================= */

    match /events/{eventId}/members/{userId} {
      // lecture équipe
      allow read: if isEventMember(eventId);

      // IMPORTANT :
      // permet la création initiale du créateur dans le batch
      allow create: if isApproved() &&
        (
          request.auth.uid == userId ||
          isEventAdmin(eventId)
        );

      allow update, delete: if isEventAdmin(eventId);
    }

    // collectionGroup(members)
    match /{path=**}/members/{userId} {
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          (
            resource != null &&
            request.auth.uid == resource.data.uid
          ) ||
          isOwner()
        );
    }

    /* =========================
       POIS PUBLIC
    ========================= */

    match /events/{eventId}/pois_public/{poiId} {
      allow read: if
        isEventPublished(eventId) ||
        isEventMember(eventId);

      allow write: if
        isAdminOrEditor(eventId);
    }

    /* =========================
       POIS PRIVÉS
    ========================= */

    match /events/{eventId}/pois/{poiId} {
      allow read: if
        isEventPublished(eventId) ||
        isEventMember(eventId);

      allow create, update, delete: if
        isAdminOrEditor(eventId);

      match /reviews/{reviewId} {
        allow read: if
          isEventPublished(eventId) ||
          isEventMember(eventId);

        allow create: if isApproved();

        allow update, delete: if
          isAdminOrEditor(eventId) ||
          (
            resource != null &&
            request.auth.uid == resource.data.userId
          );
      }
    }

    /* =========================
       CONFIG EVENT
    ========================= */

    match /events/{eventId}/config/{docId} {
      allow read: if
        isEventPublished(eventId) ||
        isEventMember(eventId);

      // IMPORTANT :
      // autorise création initiale dans batch
      allow create: if isApproved();

      allow update, delete: if
        isEventAdmin(eventId);
    }

    /* =========================
       CONFIG PORTAIL
    ========================= */

    match /config/{docId} {
      allow read: if true;

      allow write: if isOwner();
    }

    /* =========================
       USERS GLOBAL
    ========================= */

    match /users/{userId} {
      // confidentialité stricte
      allow read: if
        isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isOwner()
        );

      allow create: if
        isAuthenticated() &&
        request.auth.uid == userId;

      allow update: if
        isOwner() ||
        (
          request.auth.uid == userId &&
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny([
              'isApproved',
              'role'
            ])
        );
    }

    /* =========================
       LEGACY ROOT
    ========================= */

    match /pois/{poiId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /pois_public/{poiId} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}