rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    function isGlobalAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(getUserId())).data.role == "admin";
    }

    function getEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isEventPublished(eventId) {
      let eventPath = /databases/$(database)/documents/events/$(eventId);
      return exists(eventPath) && get(eventPath).data.status == "published";
    }

    function getMember(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/members/$(getUserId()));
    }

    function isEventMember(eventId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/events/$(eventId)/members/$(getUserId())) ||
        isGlobalAdmin()
      );
    }

    function getRole(eventId) {
      return isEventMember(eventId)
        ? (isGlobalAdmin() ? "admin" : getMember(eventId).data.role)
        : null;
    }

    function isOwner(eventId) {
      return isAuthenticated() &&
        (getEvent(eventId).data.ownerId == getUserId() || isGlobalAdmin());
    }

    function isAdmin(eventId) {
      return isEventMember(eventId) &&
        (getRole(eventId) == "admin" || isGlobalAdmin());
    }

    function isEditor(eventId) {
      return isEventMember(eventId) &&
        (getRole(eventId) == "editor" || isGlobalAdmin());
    }

    function isAdminOrEditor(eventId) {
      return isOwner(eventId) || isAdmin(eventId) || isEditor(eventId);
    }

    function isAdminOnly(eventId) {
      return isOwner(eventId) || isAdmin(eventId);
    }

    /* =========================
       EVENTS ROOT
    ========================= */

    match /events/{eventId} {
      // lecture autorisée si connecté + publié OU membre
      allow read: if isAuthenticated() && (
        isEventPublished(eventId) || isEventMember(eventId)
      );

      allow create: if isAuthenticated();

      allow update, delete: if isOwner(eventId);
    }

    /* =========================
       MEMBERS
    ========================= */

    match /events/{eventId}/members/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(eventId);
      allow update, delete: if isAdminOnly(eventId);
    }

    // 🔥 IMPORTANT : nécessaire pour collectionGroup
    match /{path=**}/members/{userId} {
      allow read: if isAuthenticated();
    }

    /* =========================
       CONFIG
    ========================= */

    match /events/{eventId}/config/{docId} {
      allow read: if isAuthenticated() && (
        isEventPublished(eventId) || isEventMember(eventId)
      );

      allow write: if isAdminOnly(eventId);
    }

    /* =========================
       POIS (FULL)
    ========================= */

    match /events/{eventId}/pois/{poiId} {
      allow read: if isAuthenticated() && (
        isEventPublished(eventId) || isEventMember(eventId)
      );

      allow create, update, delete: if isAdminOrEditor(eventId);
    }

    /* =========================
       POIS LITE (CARTE)
    ========================= */

    match /events/{eventId}/pois_public/{poiId} {
      // 👇 lecture publique si event publié
      allow read: if isEventPublished(eventId) || isEventMember(eventId);

      allow write: if isAdminOrEditor(eventId);
    }

    /* =========================
       REVIEWS
    ========================= */

    match /events/{eventId}/pois/{poiId}/reviews/{reviewId} {
      allow read: if isEventPublished(eventId) || isEventMember(eventId);

      allow create: if isAuthenticated();

      allow update, delete: if isAdminOrEditor(eventId)
        || request.auth.uid == resource.data.userId;
    }

    /* =========================
       USERS GLOBAL
    ========================= */

    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isGlobalAdmin());

      allow write: if isAuthenticated() &&
        (request.auth.uid == userId || isGlobalAdmin());
    }

    /* =========================
       LEGACY (TEMPORAIRE)
    ========================= */

    match /pois/{poiId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /pois_public/{poiId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}