rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       Fonctions utilitaires
       ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isRole(role) {
        return isSignedIn() && getUserData(request.auth.uid).role == role;
    }
    
    function isOneOfRoles(roles) {
        return isSignedIn() && getUserData(request.auth.uid).role in roles;
    }

    function isAdmin() {
      return isOneOfRoles(['admin']);
    }

    function isEditorOrAdmin() {
      return isOneOfRoles(['editor', 'admin']);
    }

    /* =========================
       USERS
       ========================= */
    match /users/{userId} {

      // Lecture : N'importe quel utilisateur connecté peut lire les données des autres.
      // C'est nécessaire pour que les règles de Storage (si on les réactive) puissent fonctionner.
      allow read: if isSignedIn();

      // Création : Le premier utilisateur DOIT être admin. Les suivants peuvent être 'user'.
      allow create: if isSignedIn() && request.auth.uid == userId && (
          (
            size(/databases/$(database)/documents/users) == 0 &&
            request.resource.data.role == 'admin'
          ) ||
          (
            size(/databases/$(database)/documents/users) > 0 &&
            request.resource.data.role == 'user'
          )
        );

      // Mise à jour du profil (sans rôle)
      allow update: if isOwner(userId)
        && !('role' in request.resource.data);

      // Modification du rôle : admin uniquement
      allow update: if isAdmin()
        && ('role' in request.resource.data);

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }

    /* =========================
       POIS
       ========================= */
    match /pois/{poiId} {
      allow read: if true;
      allow create, update, delete: if isEditorOrAdmin();

      /* =========================
         REVIEWS (sous-collection)
         ========================= */
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
