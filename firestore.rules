rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data;
    }

    // Utilisateur validé par owner
    function isApproved() {
      return isAuthenticated() &&
        getUserData().isApproved == true;
    }

    // Owner plateforme
    function isOwner() {
      return isAuthenticated() &&
        getUserData().role == "owner";
    }

    function getEvent(eventId) {
      return get(
        /databases/$(database)/documents/events/$(eventId)
      );
    }

    function isEventPublished(eventId) {
      let eventPath =
        /databases/$(database)/documents/events/$(eventId);

      return exists(eventPath) &&
        get(eventPath).data.status == "published";
    }

    function areReviewsEnabled(eventId) {
      let configPath =
        /databases/$(database)/documents/events/$(eventId)/config/main;

      return !exists(configPath) ||
        get(configPath).data.reviewsEnabled != false;
    }

    function isValidReviewCreate(poiId) {
      return request.resource.data.keys().hasOnly([
        "userId",
        "userName",
        "rating",
        "comment",
        "poiId",
        "createdAt"
      ]) &&
      request.resource.data.keys().hasAll([
        "userId",
        "userName",
        "rating",
        "comment",
        "poiId",
        "createdAt"
      ]) &&
      request.resource.data.userId == getUserId() &&
      request.resource.data.poiId == poiId &&
      request.resource.data.rating is number &&
      request.resource.data.rating >= 1 &&
      request.resource.data.rating <= 5 &&
      request.resource.data.comment is string &&
      request.resource.data.comment.size() >= 10 &&
      request.resource.data.comment.size() <= 2000 &&
      request.resource.data.userName is string &&
      request.resource.data.userName.size() > 0 &&
      request.resource.data.userName.size() <= 120 &&
      request.resource.data.createdAt == request.time;
    }

    function isValidReviewUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "rating",
        "comment"
      ]) &&
      request.resource.data.userId == resource.data.userId &&
      request.resource.data.poiId == resource.data.poiId &&
      request.resource.data.createdAt == resource.data.createdAt &&
      request.resource.data.userName == resource.data.userName &&
      request.resource.data.rating is number &&
      request.resource.data.rating >= 1 &&
      request.resource.data.rating <= 5 &&
      request.resource.data.comment is string &&
      request.resource.data.comment.size() >= 10 &&
      request.resource.data.comment.size() <= 2000;
    }

    function isEventMember(eventId) {
      return isAuthenticated() &&
        (
          exists(
            /databases/$(database)/documents/events/$(eventId)/members/$(getUserId())
          ) ||
          isOwner()
        );
    }

    function getRole(eventId) {
      return isEventMember(eventId)
        ? (
            isOwner()
              ? "admin"
              : get(
                  /databases/$(database)/documents/events/$(eventId)/members/$(getUserId())
                ).data.role
          )
        : null;
    }

    function isEventAdmin(eventId) {
      let role = getRole(eventId);

      return isAuthenticated() &&
        (
          role == "admin" ||
          getEvent(eventId).data.adminId == getUserId() ||
          isOwner()
        );
    }

    function isAdminOrEditor(eventId) {
      let role = getRole(eventId);

      return (
        role == "admin" ||
        role == "editor" ||
        isEventAdmin(eventId)
      );
    }

    function isValidEventRole(role) {
      return role == "admin" || role == "editor";
    }

    /* =========================
       EVENTS ROOT
    ========================= */

    match /events/{eventId} {
      allow get: if
        resource.data.status == "published" ||
        isEventMember(eventId);

      allow list: if
        isOwner() ||
        resource.data.status == "published";

      allow create: if
        isApproved() &&
        (
          isOwner() ||
          request.resource.data.adminId == getUserId()
        ) &&
        request.resource.data.status == "draft";

      allow update, delete: if isEventAdmin(eventId);
    }

    /* =========================
       MEMBERS
    ========================= */

    match /events/{eventId}/members/{userId} {
      // lecture équipe
      allow read: if isEventMember(eventId);

      // IMPORTANT :
      // permet la création initiale du créateur après création du document event
      allow create: if isAuthenticated() &&
        (
          (
            request.auth.uid == userId &&
            request.resource.data.uid == userId &&
            request.resource.data.role == "admin"
          ) ||
          isOwner() ||
          isEventAdmin(eventId)
        ) &&
        isValidEventRole(request.resource.data.role);

      allow update: if isEventAdmin(eventId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "role"
        ]) &&
        isValidEventRole(request.resource.data.role);

      allow delete: if isEventAdmin(eventId);
    }

    // collectionGroup(members)
    match /{path=**}/members/{userId} {
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          (
            resource != null &&
            request.auth.uid == resource.data.uid
          ) ||
          isOwner()
        );
    }

    /* =========================
       POIS PUBLIC
    ========================= */

    match /events/{eventId}/pois_public/{poiId} {
      allow read: if
        isEventPublished(eventId) ||
        isEventMember(eventId);

      allow write: if
        isAdminOrEditor(eventId);
    }

    /* =========================
       POIS PRIVÉS
    ========================= */

    match /events/{eventId}/pois/{poiId} {
      allow read: if
        isEventPublished(eventId) ||
        isEventMember(eventId);

      allow create, update, delete: if
        isAdminOrEditor(eventId);

      match /reviews/{reviewId} {
        allow read: if
          isEventPublished(eventId) ||
          isEventMember(eventId);

        allow create: if
          isApproved() &&
          areReviewsEnabled(eventId) &&
          isValidReviewCreate(poiId) &&
          (
            isEventPublished(eventId) ||
            isEventMember(eventId)
          );

        allow update: if
          isAdminOrEditor(eventId) ||
          (
            isAuthenticated() &&
            resource != null &&
            request.auth.uid == resource.data.userId &&
            isValidReviewUpdate()
          );

        allow delete: if
          isAdminOrEditor(eventId) ||
          (
            isAuthenticated() &&
            resource != null &&
            request.auth.uid == resource.data.userId
          );
      }
    }

    /* =========================
       CONFIG EVENT
    ========================= */

    match /events/{eventId}/config/{docId} {
      allow read: if
        isEventPublished(eventId) ||
        isEventMember(eventId);

      // IMPORTANT :
      // autorise création initiale après création du document event
      allow create: if
        isOwner() ||
        isEventAdmin(eventId);

      allow update, delete: if
        isEventAdmin(eventId);
    }

    /* =========================
       CONFIG PORTAIL
    ========================= */

    match /config/{docId} {
      allow read: if true;

      allow write: if isOwner();
    }

    /* =========================
       USERS GLOBAL
    ========================= */

    match /users/{userId} {
      // confidentialité stricte
      allow read: if
        isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isOwner()
        );

      allow create: if
        isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.role == "user" &&
        request.resource.data.isApproved == true;

      allow update: if
        isOwner() ||
        (
          request.auth.uid == userId &&
          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny([
              'isApproved',
              'role'
            ])
        );
    }

    /* =========================
       LEGACY ROOT
    ========================= */

    match /pois/{poiId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /pois_public/{poiId} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}
